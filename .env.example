# AI Council — API keys for hosted seats
# Copy this file to ".env" and paste your keys after each "=".
# Leave any line blank to skip that seat — the council degrades gracefully (no crash).
# Local Ollama seats need NO key and ignore this file.

# NVIDIA NIM — heavyweight seat (large model your GPU can't run). Free tier.
# Get key: https://build.nvidia.com/  (login -> any model -> "Get API Key")
NVIDIA_API_KEY=

# Groq — fast seat (snappy Llama/Qwen). Free tier.
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Google AI Studio (Gemini) — researcher + chair seat. 1M context. Free tier.
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter — agentic builder seat (Kimi K2.x etc). Free models available.
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cerebras — ultra-fast inference seat. Free tier.
# Get key: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
